# Normalize line endings — store LF in repo, check out native on each OS
* text=auto

# Scripts that must keep their native endings
*.bat   text eol=crlf
*.ps1   text eol=crlf
*.sh    text eol=lf

# Binary assets — never normalize
*.png   binary
*.ico   binary
*.jpg   binary
*.pt    binary
*.exe   binary
*.hex   binary
