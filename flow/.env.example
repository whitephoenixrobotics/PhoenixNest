# Database
DATABASE_URL=postgresql+asyncpg://phoenix:phoenix_secret@localhost:5432/phoenix_flow

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080   # 7 days — desktop stays signed in

# Google OAuth — create at https://console.cloud.google.com (Credentials → OAuth client ID, type "Web application")
# Authorized redirect URI must exactly match GOOGLE_REDIRECT_URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Where the OAuth callback sends users back to
FRONTEND_URL=http://localhost:3000
DESKTOP_PROTOCOL=phoenixflow

# Comma-separated emails auto-promoted to admin + approved on first sign-in
# (use this to bootstrap the very first admin account)
ADMIN_EMAILS=you@example.com

# AI APIs
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# NextAuth
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# API
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
