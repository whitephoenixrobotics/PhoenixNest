{
  "$schema": "./modules.schema.json",
  "version": "1.0.0",
  "ecosystem": "PhoenixNest",
  "modules": [
    {
      "id": "ai-flow",
      "name": "PhoenixFlow",
      "path": "flow",
      "icon": "🤖",
      "description": "Visual AI task automation — node editor, execution engine, and desktop app (FastAPI + Next.js + Electron)",
      "stack": ["fastapi", "nextjs", "electron", "python"],
      "status": "active",
      "launch": {
        "command": "start.bat",
        "cwd": "flow",
        "shell": true
      },
      "url": "http://localhost:3000",
      "dependsOn": []
    },
    {
      "id": "circuit",
      "name": "Circuit",
      "path": "circuit",
      "icon": "🔌",
      "description": "IoT / hardware integration layer (firmware, drivers, device control)",
      "stack": [],
      "status": "reserved",
      "launch": null,
      "url": null,
      "dependsOn": []
    },
    {
      "id": "python",
      "name": "PhoenixPy",
      "path": "python",
      "icon": "🐍",
      "description": "Local Python IDE — notebook, editor, terminal, and AI assistant (FastAPI + Next.js)",
      "stack": ["python", "fastapi", "nextjs"],
      "status": "active",
      "launch": {
        "command": "start.bat",
        "cwd": "python",
        "shell": true
      },
      "url": "http://localhost:3200",
      "dependsOn": []
    }
  ]
}
